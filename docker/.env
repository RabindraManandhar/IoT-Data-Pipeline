# Kafka brokers configuration
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka1:29093,2@kafka2:29093,3@kafka3:29093
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=3
KAFKA_DELAY_MS=0
KAFKA_MIN_ISR=2
KAFKA_LOG_REPLICATION_FACTOR=3

CLUSTER_ID=M87IboZAScmgU_NXvNQWcw

# Kafka-broker-1 config
KAFKA_NODE_ID_1=1
KAFKA_LISTENERS_1=PLAINTEXT://kafka1:9092,CONTROLLER://kafka1:29093,PLAINTEXT_HOST://0.0.0.0:29092
KAFKA_ADVERTISED_LISTENERS_1=PLAINTEXT://kafka1:9092,PLAINTEXT_HOST://localhost:29092

# Kafka-broker-2 config
KAFKA_NODE_ID_2=2
KAFKA_LISTENERS_2=PLAINTEXT://kafka2:9092,CONTROLLER://kafka2:29093,PLAINTEXT_HOST://0.0.0.0:29092
KAFKA_ADVERTISED_LISTENERS_2=PLAINTEXT://kafka2:9092,PLAINTEXT_HOST://localhost:29093

# Kafka-broker-3 config
KAFKA_NODE_ID_3=3
KAFKA_LISTENERS_3=PLAINTEXT://kafka3:9092,CONTROLLER://kafka3:29093,PLAINTEXT_HOST://0.0.0.0:29092
KAFKA_ADVERTISED_LISTENERS_3=PLAINTEXT://kafka3:9092,PLAINTEXT_HOST://localhost:29094

# Schema Registry config
SCHEMA_REGISTRY_KAFKASTORE_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
SCHEMA_REGISTRY_LISTENERS=http://0.0.0.0:8081
SCHEMA_REGISTRY_AVRO_COMPATIBILITY_LEVEL=BACKWARD
SCHEMA_REGISTRY_KAFKASTORE_TOPIC_REPLICATION_FACTOR=3

# Kafka Producer, Consumer, UI config
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_TOPIC_NAME=iot-sensor-data

# Kafka UI config
KAFKA_UI_CLUSTER_NAME=local-cluster

# Kafka Producer config
IOT_NUM_DEVICES=8
IOT_DATA_INTERVAL_SEC=1.0

# Kafka Consumer config
KAFKA_CONSUMER_GROUP_ID=iot-data-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# Postgres config
POSTGRES_URL=postgresql://iceberg:iceberg@postgres:5432/iceberg_catalog

# MinIO config
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=user
MINIO_ROOT_PASSWORD=password